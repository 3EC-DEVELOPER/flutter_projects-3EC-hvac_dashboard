// Application-level settings for the Runner target.
//
// These values define the app window title, bundle identifier, and copyright.

// The application's name. By default this is also the title of the Flutter window.
PRODUCT_NAME = 3EC HVAC Dashboard

// The application's bundle identifier
PRODUCT_BUNDLE_IDENTIFIER = com.tec.hvacdashboard

// The copyright displayed in application information
PRODUCT_COPYRIGHT = Copyright © 2026 Three Energy Control Ltd. All rights reserved.
